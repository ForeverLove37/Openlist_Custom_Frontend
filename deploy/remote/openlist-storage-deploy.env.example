# Install as /root/.config/openlist-storage-deploy.env with mode 600.
OPENLIST_URL=https://pan.example.com
OPENLIST_TOKEN=replace-with-openlist-admin-token
DATA_DIR=/opt/openlist_file

WEBDAV_USER=admin
WEBDAV_PASSWORD=replace-with-stable-password
WEBDAV_ENDPOINT=https://storage.example.com/webdav
WEBDAV_MOUNT_PATH=/cloud/node_WebDav

S3_ENDPOINT=https://s3.example.com
S3_MOUNT_PATH=/cloud/node_S3
S3_BUCKET=default
S3_REGION=openlist
S3_SIGN_URL_EXPIRE=4

# The script routes WebDAV through this path and MinIO through / on S3_ENDPOINT.
WEBDAV_PROXY_PATH=/webdav
NGINX_WEBROOT=/var/www/openlist-storage
# Set this after a DNS name points at the host, then run: /root/load.sh certbot
CERTBOT_EMAIL=admin@example.com
CERTBOT_CERT_NAME=openlist-storage
# When either endpoint uses https, the deployment command requests the certificate
# automatically after confirming that the DNS A record points at this host.
CERTBOT_AUTO_ISSUE=true
