# Install as /root/.config/openlist-storage-deploy.env with mode 600.
OPENLIST_URL=https://pan.example.com
OPENLIST_TOKEN=replace-with-openlist-admin-token
DATA_DIR=/opt/openlist_file

WEBDAV_USER=admin
WEBDAV_PASSWORD=replace-with-stable-password
WEBDAV_MOUNT_PATH=/cloud/node_WebDav

S3_MOUNT_PATH=/cloud/node_S3
S3_BUCKET=default
S3_REGION=openlist
S3_SIGN_URL_EXPIRE=4

# Both services share exactly one HTTPS domain. HTTP URLs, IP addresses, and
# explicit ports are rejected. Leave STORAGE_DOMAIN empty to derive a stable
# subdomain from the Cloudflare root domain below.
STORAGE_DOMAIN=

# Legacy endpoint variables are accepted only when they are HTTPS domain URLs;
# STORAGE_DOMAIN is the preferred, authoritative setting.
S3_ENDPOINT=
WEBDAV_ENDPOINT=

# The script routes WebDAV through this path and MinIO through / on STORAGE_DOMAIN.
WEBDAV_PROXY_PATH=/webdav
NGINX_WEBROOT=/var/www/openlist-storage
WEBDAV_LISTEN_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
CERTBOT_EMAIL=admin@example.com
CERTBOT_CERT_NAME=openlist-storage
# HTTPS is mandatory. Deployment uses Cloudflare DNS validation, so port 80 is
# never exposed and certificates renew without an HTTP listener.
CERTBOT_AUTO_ISSUE=true

# Required automatic Cloudflare DNS mode. The token needs Zone DNS Edit
# permission for the root domain. It may instead be placed, together with
# CF_ROOT_DOMAIN, in /root/domain_info.txt (mode 600).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ROOT_DOMAIN=example.com
CLOUDFLARE_AUTO_DNS=true
CLOUDFLARE_SUBDOMAIN_PREFIX=cloudfs-ser
CLOUDFLARE_RECORD_TTL=60
CLOUDFLARE_PROXIED=false
CLOUDFLARE_DNS_WAIT_SECONDS=90
CLOUDFLARE_DNS_PROPAGATION_SECONDS=30

# When UFW or firewalld is active, expose only Nginx's public HTTPS port.
# MinIO and WebDAV container ports remain bound to localhost; port 80 is denied.
FIREWALL_MANAGE=true
